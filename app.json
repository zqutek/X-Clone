{
  "expo": {
    "name": "X Clone",
    "slug": "x-clone",
    "scheme": "x-clone",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "plugins": [
      "expo-router",
      "expo-image",
      "expo-font",
      "expo-splash-screen",
      "expo-notifications"
    ],
    "android": {
      "package": "com.nbi41.xclone",
      "permissions": [
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
